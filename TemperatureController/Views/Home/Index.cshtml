            //         const devicePowerData = data.power[deviceName] || data.power; 
                    
            //         if (devicePowerData) {
            //             const elVoltage = document.getElementById('val_voltage_' + deviceName);
            //             const elCurrent = document.getElementById('val_current_' + deviceName);
            //             const elPower = document.getElementById('val_power_' + deviceName);
            //             const elEnergy = document.getElementById('val_energy_' + deviceName);

            //             // Sprawdzamy czy dany element HTML faktycznie wygenerł się w DOM
            //             if (elVoltage) elVoltage.innerText = (devicePowerData.voltage || 0).toFixed(1) + " V";
            //             if (elCurrent) elCurrent.innerText = (devicePowerData.current || 0).toFixed(2) + " A";
            //             if (elPower) elPower.innerText = (devicePowerData.power || 0).toFixed(0) + " W";
            //             if (elEnergy) elEnergy.innerText = (devicePowerData.sessionEnergy || 0).toFixed(3) + " kWh";
            //         }
            //     });
            // }
            activeDevices.forEach(dev => {
                const d = powerByDevice?.[dev];
                if (!d) {
                    return;
                }

                const voltageEl = document.getElementById('val_voltage_' + dev);
                const currentEl = document.getElementById('val_current_' + dev);
                const powerEl = document.getElementById('val_power_' + dev);
                const energyEl = document.getElementById('val_energy_' + dev);

                if (voltageEl) voltageEl.innerText = (d.voltage || 0).toFixed(1) + " V";
                if (currentEl) currentEl.innerText = (d.current || 0).toFixed(2) + " A";
                if (powerEl) powerEl.innerText = (d.power || 0).toFixed(0) + " W";
                if (energyEl) energyEl.innerText = (d.sessionEnergy || 0).toFixed(3) + " kWh";
            });

            // START TIME + DURATION
            document.getElementById('ui_duration').innerText = data.processDuration ?? data.ProcessDuration ?? "00:00:00";
            // ... (reszta kodu wykresu i czasu zostaje bez zmian)

            // START TIME + DURATION
            document.getElementById('ui_duration').innerText = data.processDuration ?? data.ProcessDuration ?? "00:00:00";
            document.getElementById('ui_startTime').innerText = data.startTimeStr ?? data.StartTimeStr ?? "--:--:--";

            isRecording = !!(data.isRecording ?? data.IsRecording);
            setToggleButtonState();

            // LIVE points
            const now = new Date().toLocaleTimeString();
            processChart.data.labels.push(now);
            processChart.data.datasets[0].data.push(temperatures?.Temp_Keg ?? temperatures?.temp_Keg ?? null);
            processChart.data.datasets[1].data.push(temperatures?.Temp_Bufor ?? temperatures?.temp_Bufor ?? null);
            processChart.data.datasets[2].data.push(temperatures?.Temp_10p ?? temperatures?.temp_10p ?? null);
            processChart.data.datasets[3].data.push(temperatures?.Temp_Glowica ?? temperatures?.temp_Glowica ?? null);
            processChart.data.datasets[4].data.push(temperatures?.Temp_Woda ?? temperatures?.temp_Woda ?? null);
            processChart.data.datasets[5].data.push(power?.power ?? power?.Power ?? null);

            if (processChart.data.labels.length > 120) {
                processChart.data.labels.shift();
                processChart.data.datasets.forEach(d => d.data.shift());
            }

            processChart.update();

            const lamp = document.getElementById('valve_range_lamp');
            const text = document.getElementById('valve_range_text');
            const inRange = !!(data.isValveEnabled ?? data.IsValveEnabled); // temp10p pomiędzy ValveThresholdTempMin i ValveThresholdTempMax

            lamp.classList.remove('status-lamp-green', 'status-lamp-red');
            lamp.classList.add(inRange ? 'status-lamp-green' : 'status-lamp-red');
            text.innerText = inRange ? "ZAŁĄCZONY" : "WYŁĄCZONY";


            heartbeatEnabled = !!(data.isHeartbeatReceptionEnabled ?? data.IsHeartbeatReceptionEnabled);
setHeartbeatButtonState();
        });

        /// 1) Dociąganie korekt z pliku konfiguracyjnego
        async function loadCalibrations() {
            try {
                const response = await fetch('/api/config/calibrations');
                if (!response.ok) throw new Error('HTTP error');

                const c = await response.json();

                correctionMap.Temp_Keg.value = c.temp_Keg ?? 0;
                correctionMap.Temp_Bufor.value = c.temp_Bufor ?? 0;
                correctionMap.Temp_10p.value = c.temp_10p ?? 0;
                correctionMap.Temp_Glowica.value = c.temp_Glowica ?? 0;
                correctionMap.Temp_Woda.value = c.temp_Woda ?? 0;

                renderCorrection('Temp_Keg');
                renderCorrection('Temp_Bufor');
                renderCorrection('Temp_10p');
                renderCorrection('Temp_Glowica');
                renderCorrection('Temp_Woda');
            } catch (err) {
                console.error("Błąd pobierania korekt:", err);
            }
        }

        /// 2) updateFileName jako async (żeby mieć pewność, że backend przyjął nazwę)
        async function updateFileName(newName) {
            const response = await fetch('/api/process/set-filename', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: newName })
            });

            if (!response.ok) {
                throw new Error("Nie udało się ustawić nazwy pliku.");
            }
        }

        /// 3) Inicjalizacja w poprawnej kolejności
        async function initializeDashboard() {
            setToggleButtonState();
            setHeartbeatButtonState();

            const fileName = document.getElementById('ui_filename').value;

            try {
                await updateFileName(fileName);
            } catch (err) {
                console.warn("Nie udało się ustawić nazwy pliku:", err);
            }

            try {
                await loadCalibrations();
            } catch (err) {
                console.warn("Nie udało się pobrać korekt:", err);
            }

            try {
                await loadHeartbeatStatus();
            } catch (err) {
                console.warn("Nie udało się pobrać statusu heartbeat:", err);
            }

            loadChartHistory();
            setInterval(loadChartHistory, 15000);

            try {
                await connection.start();
            } catch (err) {
                console.error("Nie udało się uruchomić połączenia SignalR:", err);
            }

            try {
                await loadWeather();
            } catch (err) {
                console.warn("Nie udało się pobrać pogody:", err);
            }

            setInterval(loadWeather, 300000); // co 5 min
        }

        initializeDashboard();

        /// Wysyłka korekty sensora do backendu
        async function sendCorrection(sensorName, offsetValue) {
            try {
                await fetch('/api/config/update-calibration', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sensorName: sensorName, offset: parseFloat(offsetValue) })
                });
            } catch (err) {
                console.error("Błąd aktualizacji korekty:", err);
            }
        }

        /// Wysyłka komentarza do backendu (zapisywany później przez ProcessMonitorService do CSV)
        async function updateComment(commentText) {
            try {
                const response = await fetch('/api/process/comment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ comment: commentText ?? "" })
                });

                if (!response.ok) {
                    throw new Error("HTTP error");
                }
            } catch (err) {
                console.error("Błąd aktualizacji komentarza:", err);
            }
        }

        async function loadWeather() {
            try {
                const response = await fetch('/api/weather/current');
                if (!response.ok) throw new Error('HTTP error');

                const weather = await response.json();
                document.getElementById('val_weather_temp').innerText = `${weather.temperatureC.toFixed(1)} °C`;
                document.getElementById('val_weather_pressure').innerText = `${weather.pressureHpa.toFixed(1)} hPa`;
            } catch (err) {
                console.error("Błąd pobierania pogody:", err);
            }
        }

        setInterval(loadWeather, 300000); // co 5 minut

        const correctionMap = {
            Temp_Keg: { valueEl: 'corr_temp_keg', value: 0 },
            Temp_Bufor: { valueEl: 'corr_temp_bufor', value: 0 },
            Temp_10p: { valueEl: 'corr_temp_10p', value: 0 },
            Temp_Glowica: { valueEl: 'corr_temp_glowica', value: 0 },
            Temp_Woda: { valueEl: 'corr_temp_woda', value: 0 }
        };

        function renderCorrection(sensorName) {
            const c = correctionMap[sensorName];
            document.getElementById(c.valueEl).innerText = c.value.toFixed(2);
        }

        async function changeCorrection(valueEl, delta) {
            const sensorNameMap = {
                corr_temp_keg: "Temp_Keg",
                corr_temp_bufor: "Temp_Bufor",
                corr_temp_10p: "Temp_10p",
                corr_temp_glowica: "Temp_Glowica",
                corr_temp_woda: "Temp_Woda"
            };

            const sensorName = sensorNameMap[valueEl];
            const c = correctionMap[sensorName];

            c.value = Math.max(-15, Math.min(15, +(c.value + delta).toFixed(2)));
            renderCorrection(sensorName);
            await sendCorrection(sensorName, c.value);
        }

        let isHeartbeatActive = false;

        let heartbeatEnabled = false;
let heartbeatToggleInProgress = false;

function setHeartbeatButtonState() {
    const sw = document.getElementById('heartbeat_switch');
    const txt = document.getElementById('heartbeat_label_text');
    if (!sw || !txt) return;

    sw.disabled = heartbeatToggleInProgress;
    sw.checked = heartbeatEnabled;

    if (heartbeatToggleInProgress) {
        txt.innerText = heartbeatEnabled
            ? 'ODBIÓR SERCA: WYŁĄCZANIE...'
            : 'ODBIÓR SERCA: WŁĄCZANIE...';
    } else {
        txt.innerText = heartbeatEnabled
            ? 'ODBIÓR SERCA: WŁĄCZONY'
            : 'ODBIÓR SERCA: WYŁĄCZONY';
    }
}

async function loadHeartbeatStatus() {
    try {
        const response = await fetch('/api/process/heartbeat-status');
        if (!response.ok) throw new Error('HTTP error');
        const data = await response.json();
        heartbeatEnabled = !!data.enabled;
        setHeartbeatButtonState();
    } catch (err) {
        console.error('Błąd pobierania statusu heartbeat:', err);
        heartbeatEnabled = false;
        setHeartbeatButtonState();
    }
}

async function toggleHeartbeat() {
    if (heartbeatToggleInProgress) return;

    const sw = document.getElementById('heartbeat_switch');
    if (!sw) return;

    const requestedState = !!sw.checked;
    heartbeatToggleInProgress = true;
    setHeartbeatButtonState();

    try {
        const response = await fetch('/api/process/heartbeat-toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ enabled: requestedState })
        });

        if (!response.ok) throw new Error('HTTP error');
        const data = await response.json();
        heartbeatEnabled = !!data.enabled;
    } catch (e) {
        console.error(e);
        alert('Nie udało się zmienić stanu odbioru serca.');
    } finally {
        heartbeatToggleInProgress = false;
        setHeartbeatButtonState();
    }
}

