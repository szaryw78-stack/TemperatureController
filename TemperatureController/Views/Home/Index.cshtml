        // Przekazanie listy widocznych urządzeń z poziomu backendu do JavaScriptu
         @* const activeTuyaDevices = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(visibleTuyaDevices));*@
        const activeDevices = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(visibleDevices));

        connection.on("ReceiveProcessData", function (data) {
            const temperatures = data.temperatures ?? data.Temperatures ?? {};
            const powerByDevice = data.powerByDevice ?? data.PowerByDevice ?? {};
            const power = data.power ?? data.Power ?? null;

            if (temperatures && Object.keys(temperatures).length > 0) {
                const t = temperatures;
                const getTemp = (legacyKey, camelKey) => {
                    const value = t[legacyKey] ?? t[camelKey];
                    return typeof value === 'number' ? value : null;
                };

                const tempKeg = getTemp('Temp_Keg', 'temp_Keg');
                const tempBufor = getTemp('Temp_Bufor', 'temp_Bufor');
                const temp10p = getTemp('Temp_10p', 'temp_10p');
                const tempGlowica = getTemp('Temp_Glowica', 'temp_Glowica');
                const tempWoda = getTemp('Temp_Woda', 'temp_Woda');

                document.getElementById('val_temp_keg').innerText = tempKeg !== null ? tempKeg.toFixed(2) + " °C" : "-- °C";
                document.getElementById('val_temp_bufor').innerText = tempBufor !== null ? tempBufor.toFixed(2) + " °C" : "-- °C";
                document.getElementById('val_temp_10p').innerText = temp10p !== null ? temp10p.toFixed(2) + " °C" : "-- °C";
                document.getElementById('val_temp_glowica').innerText = tempGlowica !== null ? tempGlowica.toFixed(2) + " °C" : "-- °C";
                document.getElementById('val_temp_woda').innerText = tempWoda !== null ? tempWoda.toFixed(2) + " °C" : "-- °C";
            }

