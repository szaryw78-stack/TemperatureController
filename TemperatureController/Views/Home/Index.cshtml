                                {
                                    visibleTuyaDevices.Add(device.Name); // Doda m.in. "Column", "Pump"
                                }
                            }
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                // Zabezpieczenie na wypadek problemów z plikiem JSON
                Console.WriteLine("Błąd odczytu deviceconfiguration.json: " + ex.Message);
            }
        }

        @if(visibleTuyaDevices.Count == 0)
        {
            <div style="color: red; margin-bottom: 20px;">Brak urządzeń do wyświetlenia lub błąd odczytu z pliku deviceconfiguration.json.</div>
        }

        @foreach(var deviceName in visibleTuyaDevices)
        {
            <div style="margin-bottom: 5px; font-weight: bold; color: var(--fiori-blue);">Moduł: @deviceName</div>
            <div class="tiles-grid" style="margin-bottom: 25px;">
                <div class="tile">
                    <div class="tile-header">Napięcie</div>
                    <div class="tile-value" id="val_voltage_@deviceName">-- V</div>
                </div>
                <div class="tile">
                    <div class="tile-header">Prąd</div>
                    <div class="tile-value" id="val_current_@deviceName">-- A</div>
                </div>
                <div class="tile">
                    <div class="tile-header">Moc Bieżąca</div>
                    <div class="tile-value" id="val_power_@deviceName">-- W</div>
                </div>
                <div class="tile">
                    <div class="tile-header">Zużyta Moc w Sesji</div>
                    <div class="tile-value" id="val_energy_@deviceName">-- kWh</div>
                </div>
            </div>
        } *@
        <div class="section-title">Sekcja 2: Zarządzanie energią</div>
        
        @{
            var configPath = System.IO.Path.Combine(System.IO.Directory.GetCurrentDirectory(), "deviceconfiguration.json");
            var visibleDevices = new List<string>();
            if (System.IO.File.Exists(configPath))
            {
                var json = System.IO.File.ReadAllText(configPath);
                using (var doc = System.Text.Json.JsonDocument.Parse(json))
                {
                    if (doc.RootElement.TryGetProperty("Tuya", out var tuya))
                    {
                        foreach (var dev in tuya.EnumerateObject())
                        {
                            if (dev.Value.TryGetProperty("VisibleOnDashboard", out var vis) && vis.GetBoolean())
                                visibleDevices.Add(dev.Name);
                        }
                    }
                }
            }
        }

        @foreach(var dev in visibleDevices)
        {
            <div style="margin: 15px 0 5px 0; font-weight: bold; color: var(--fiori-blue);">@dev</div>
            <div class="tiles-grid">
                <div class="tile"><div class="tile-header">Napięcie</div><div class="tile-value" id="val_voltage_@dev">-- V</div></div>
                <div class="tile"><div class="tile-header">Prąd</div><div class="tile-value" id="val_current_@dev">-- A</div></div>
                <div class="tile"><div class="tile-header">Moc</div><div class="tile-value" id="val_power_@dev">-- W</div></div>
                <div class="tile"><div class="tile-header">Sesja</div><div class="tile-value" id="val_energy_@dev">-- kWh</div></div>
            </div>
        }
        @* wykres *@
        <div class="section-title">Wykres online (SignalR)</div>
        <div class="chart-container">
            <div class="control-item" style="margin-bottom: 15px;">
                <strong>Widoczność na wykresie:</strong>
                <div style="display: flex; gap: 15px; flex-wrap: wrap; margin-top: 5px;">
                    <label style="cursor: pointer;">
                        <input type="checkbox" checked onchange="toggleSeries(0, this.checked)"> Temp. Keg (Czerwona)
                    </label>
                    <label style="cursor: pointer;">
                        <input type="checkbox" checked onchange="toggleSeries(1, this.checked)"> Temp. Bufor (Niebieska)
                    </label>
                    <label style="cursor: pointer;">
                        <input type="checkbox" checked onchange="toggleSeries(2, this.checked)"> Temp. 10p (Pomarańczowa)
                    </label>
                    <label style="cursor: pointer;">
                        <input type="checkbox" checked onchange="toggleSeries(3, this.checked)"> Temp. Głowica (Zielona)
                    </label>
                    <label style="cursor: pointer;">
                        <input type="checkbox" checked onchange="toggleSeries(4, this.checked)"> Temp. Woda (Fioletowa)
                    </label>
                    <label style="cursor: pointer;">
                        <input type="checkbox" checked onchange="toggleSeries(5, this.checked)"> Moc (Szara, przerywana)
                    </label>
                </div>
            </div>
            <canvas id="processChart"></canvas>
        </div>

        <div class="section-title">Sekcja 3: Pogoda</div>
        <div class="tiles-grid">
            <div class="tile">
                <div class="tile-header">Temperatura zewnętrzna</div>
                <div class="tile-value" id="val_weather_temp">-- °C</div>
            </div>
            <div class="tile">
                <div class="tile-header">Ciśnienie atmosferyczne</div>
                <div class="tile-value" id="val_weather_pressure">-- hPa</div>
            </div>
        </div>
    </div>

    <script>
        let isRecording = false;
        let toggleInProgress = false;

        function setToggleButtonState() {
            const btn = document.getElementById('btn_processToggle');
            const btnText = document.getElementById('btn_text');
            const spinner = document.getElementById('btn_spinner');

            if (toggleInProgress) {
                btn.disabled = true;
                spinner.classList.remove('d-none');
                btn.className = isRecording ? "btn btn-stop" : "btn btn-start";
                btnText.innerText = isRecording ? "ZATRZYMYWANIE..." : "URUCHAMIANIE...";
                return;
            }

            btn.disabled = false;
            spinner.classList.add('d-none');
            btn.className = isRecording ? "btn btn-stop" : "btn btn-start";
            btnText.innerText = isRecording ? "KONIEC PROCESU" : "START PROCESU";
        }

        async function toggleProcess() {
            if (toggleInProgress) return;

            toggleInProgress = true;
            setToggleButtonState();

            try {
                const response = await fetch('/api/process/toggle', { method: 'POST' });
                if (!response.ok) throw new Error('HTTP error');

                const result = await response.json();
                isRecording = !!result.recording;
            } catch (e) {
                console.error(e);
                alert("Nie udało się przełączyć procesu.");
            } finally {
                toggleInProgress = false;
                setToggleButtonState();
            }
        }

        const ctx = document.getElementById('processChart').getContext('2d');
        const processChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: [],
                datasets: [
                    { label: 'Keg', yAxisID: 'yTemp', data: [], borderColor: '#D32030', tension: 0.1, pointRadius: 2 },
                    { label: 'Bufor', yAxisID: 'yTemp', data: [], borderColor: '#0A6ED1', tension: 0.1, pointRadius: 2 },
                    { label: '10p', yAxisID: 'yTemp', data: [], borderColor: '#E38B00', tension: 0.1, pointRadius: 2 },
                    { label: 'Głowica', yAxisID: 'yTemp', data: [], borderColor: '#00A86B', tension: 0.1, pointRadius: 2 },
                    { label: 'Woda', yAxisID: 'yTemp', data: [], borderColor: '#8E44AD', tension: 0.1, pointRadius: 2 },
                    { label: 'Moc (W)', yAxisID: 'yPower', data: [], borderColor: '#8A8D90', backgroundColor: 'rgba(138, 141, 144, 0.2)', fill: true, tension: 0.1, pointRadius: 0, borderDash: [5, 5] }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: { legend: { display: false } },
                scales: {
                    x: { display: true, title: { display: true, text: 'Czas' } },
                    yTemp: { type: 'linear', display: true, position: 'left', title: { display: true, text: 'Temperatura (°C)' } },
                    yPower: { type: 'linear', display: true, position: 'right', title: { display: true, text: 'Moc (W)' }, grid: { drawOnChartArea: false } }
                }
            }
        });

        function loadChartHistory() {
            fetch('/api/process/history')
                .then(response => response.json())
                .then(data => {
                    processChart.data.labels = [];
                    processChart.data.datasets.forEach(d => d.data = []);

                    data.forEach(row => {
                        processChart.data.labels.push(row.time);
                        processChart.data.datasets[0].data.push(row.keg);
                        processChart.data.datasets[1].data.push(row.bufor);
                        processChart.data.datasets[2].data.push(row.temp10p);
                        processChart.data.datasets[3].data.push(row.glowica);
                        processChart.data.datasets[4].data.push(row.woda);
                        processChart.data.datasets[5].data.push(row.power ?? null);
                    });

                    processChart.update();
                })
                .catch(err => console.error("Błąd pobierania historii wykresu:", err));
        }

        function toggleSeries(datasetIndex, isVisible) {
            if (processChart.isDatasetVisible(datasetIndex) !== isVisible) {
                processChart.setDatasetVisibility(datasetIndex, isVisible);
                processChart.update();
            }
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/dashboardHub")
            .withAutomaticReconnect()
            .build();

        // connection.on("ReceiveProcessData", function (data) {
        //     if (data.temperatures) {
        //         document.getElementById('val_temp_keg').innerText = data.temperatures['Temp_Keg']?.toFixed(2) + " °C";
